<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.ThanhToanController"
      stylesheets="@../css/style.css"
      VBox.vgrow="ALWAYS">

    <!-- ── Phase 3: Page Section Header ── -->
    <HBox styleClass="table-page-header" alignment="CENTER_LEFT" spacing="14">
        <Label text="💳" style="-fx-font-size: 22px;" />
        <VBox spacing="3">
            <Label text="Quản lý Thanh toán" styleClass="page-section-title" />
            <Label text="Hóa đơn, trạng thái thu và lịch sử giao dịch" styleClass="page-section-sub" />
        </VBox>
    </HBox>
    <!-- ── TOOLBAR ── -->
    <HBox styleClass="toolbar" spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" styleClass="search-field"
                   promptText="🔍  Tìm theo mã bill, mã HĐ, tên sinh viên..."
                   onAction="#handleSearch" />
        <ComboBox fx:id="cboFilter"   prefWidth="175" promptText="Trạng thái" />
        <ComboBox fx:id="cboThang"    prefWidth="90"  promptText="Tháng" />
        <ComboBox fx:id="cboNam"      prefWidth="90"  promptText="Năm" />
        <Button text="Lọc"           styleClass="btn-outline"  onAction="#handleSearch" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="💳  Thanh toán"   styleClass="btn-success" onAction="#handleThanhToan"   />
        <Button text="➕  Tạo bill"      styleClass="btn-primary" onAction="#handleTaoBill"     />
        <Button text="📋  Hàng loạt"    styleClass="btn-outline" onAction="#handleHangLoat"    />
        <Button text="🔄  Làm mới"      styleClass="btn-outline" onAction="#handleRefresh"     />
        <Button text="📥  Xuất Excel"   styleClass="btn-outline" onAction="#handleExport"      />
    </HBox>

    <!-- ── SUMMARY BAR ── -->
    <HBox styleClass="summary-chip-bar" spacing="20" alignment="CENTER_LEFT">

        <VBox alignment="CENTER" style="-fx-padding: 6 16; -fx-background-color: #D1FAE5;
                -fx-background-radius: 8; -fx-spacing: 2;">
            <Label fx:id="lblDaThu" text="0 đ"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #065F46;" />
            <Label text="Đã thu" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" />
        </VBox>

        <VBox alignment="CENTER" style="-fx-padding: 6 16; -fx-background-color: #FEF3C7;
                -fx-background-radius: 8; -fx-spacing: 2;">
            <Label fx:id="lblChuaThu" text="0 đ"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #92400E;" />
            <Label text="Chưa thu" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" />
        </VBox>

        <VBox alignment="CENTER" style="-fx-padding: 6 16; -fx-background-color: #FEE2E2;
                -fx-background-radius: 8; -fx-spacing: 2;">
            <Label fx:id="lblTreHan" text="0 bill"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #991B1B;" />
            <Label text="Trễ hạn" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" />
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <Label fx:id="lblTongBill" text="Tổng: 0 hóa đơn"
               style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" />
    </HBox>

    <!-- ── TABLE ── -->
    <ScrollPane fitToWidth="true" fitToHeight="true"
                VBox.vgrow="ALWAYS" styleClass="content-scroll">
        <VBox style="-fx-padding: 16;" spacing="0">
            <TableView fx:id="tblThanhToan" styleClass="table-view" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colMaTT"      text="Mã Bill"       prefWidth="110" />
                    <TableColumn fx:id="colMaHD"       text="Mã HĐ"        prefWidth="100" />
                    <TableColumn fx:id="colTenSV"      text="Sinh viên"     prefWidth="155" />
                    <TableColumn fx:id="colPhong"      text="Phòng"         prefWidth="75"  />
                    <TableColumn fx:id="colThangNam"   text="Tháng/Năm"    prefWidth="95"  />
                    <TableColumn fx:id="colSoTien"     text="Số tiền"       prefWidth="115" />
                    <TableColumn fx:id="colHanTT"      text="Hạn TT"       prefWidth="100" />
                    <TableColumn fx:id="colNgayTT"     text="Ngày thanh toán" prefWidth="120" />
                    <TableColumn fx:id="colPhuongThuc" text="Phương thức"   prefWidth="110" />
                    <TableColumn fx:id="colTrangThai"  text="Trạng thái"    prefWidth="120" />
                </columns>
                <placeholder>
                    <Label text="Chưa có hóa đơn nào"
                           style="-fx-text-fill: #9CA3AF; -fx-font-size: 14px;" />
                </placeholder>
            </TableView>
        </VBox>
    </ScrollPane>

</VBox>
