<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.ScrollPane?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.SinhVienController"
      stylesheets="@../css/style.css"
      VBox.vgrow="ALWAYS">

    <!-- ── Phase 3: Page Section Header ── -->
    <HBox styleClass="table-page-header" alignment="CENTER_LEFT" spacing="14">
        <Label text="👤" style="-fx-font-size: 22px;" />
        <VBox spacing="3">
            <Label text="Quản lý Sinh viên" styleClass="page-section-title" />
            <Label text="Danh sách và thông tin sinh viên cư trú tại ký túc xá" styleClass="page-section-sub" />
        </VBox>
    </HBox>
    <!-- ── Toolbar ── -->
    <HBox styleClass="toolbar" spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" styleClass="search-field"
                   promptText="🔍  Tìm theo tên, mã SV, CCCD, điện thoại..."
                   onAction="#handleSearch" prefWidth="310" />
        <ComboBox fx:id="cboFilter" prefWidth="150" promptText="Trạng thái" />
        <Button text="🔍  Tìm kiếm" styleClass="btn-primary"   onAction="#handleSearch" />
        <Button text="🔄  Làm mới"  styleClass="btn-outline"   onAction="#handleRefresh" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="➕  Thêm mới" styleClass="btn-success"   onAction="#handleAdd" />
        <Button text="✏  Sửa"       styleClass="btn-warning"   onAction="#handleEdit" />
        <Button text="🗑  Xoá"       styleClass="btn-danger"    onAction="#handleDelete" />
        <Button text="📥  Xuất Excel" styleClass="btn-outline"  onAction="#handleExport" />
    </HBox>

    <!-- ── Summary chips bar ── -->
    <HBox styleClass="summary-chip-bar" spacing="10" alignment="CENTER_LEFT">
        <Label text="📊  Tổng hợp:" style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-font-weight: bold;" />
        <Label fx:id="chipTongSV"      text="Tất cả: 0"           styleClass="chip,chip-blue"   />
        <Label fx:id="chipDangHoc"     text="Đang học: 0"         styleClass="chip,chip-green"  />
        <Label fx:id="chipDaNghi"      text="Đã nghỉ: 0"          styleClass="chip,chip-orange" />
        <Label fx:id="chipTotNghiep"   text="Tốt nghiệp: 0"       styleClass="chip,chip-gray"   />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblCount" text="Hiển thị: 0 sinh viên"
               style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;" />
    </HBox>

    <!-- ── Table ── -->
    <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS"
                styleClass="content-scroll">
        <VBox style="-fx-padding: 16;" spacing="0">
            <TableView fx:id="tblSinhVien" styleClass="table-view" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colMa"          text="Mã SV"       prefWidth="105" />
                    <TableColumn fx:id="colHoTen"        text="Họ tên"       prefWidth="185" />
                    <TableColumn fx:id="colNgaySinh"     text="Ngày sinh"    prefWidth="105" />
                    <TableColumn fx:id="colGioiTinh"     text="Giới tính"    prefWidth="85"  />
                    <TableColumn fx:id="colCCCD"         text="CCCD"         prefWidth="125" />
                    <TableColumn fx:id="colSoDienThoai"  text="Điện thoại"   prefWidth="115" />
                    <TableColumn fx:id="colKhoa"         text="Khoa"         prefWidth="160" />
                    <TableColumn fx:id="colTrangThai"    text="Trạng thái"   prefWidth="120" />
                </columns>
                <placeholder>
                    <VBox styleClass="empty-state" alignment="CENTER" spacing="10">
                        <Label text="👤" styleClass="empty-state-icon" />
                        <Label text="Không tìm thấy sinh viên" styleClass="empty-state-title" />
                        <Label text="Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm" styleClass="empty-state-sub" />
                    </VBox>
                </placeholder>
            </TableView>
        </VBox>
    </ScrollPane>

</VBox>
