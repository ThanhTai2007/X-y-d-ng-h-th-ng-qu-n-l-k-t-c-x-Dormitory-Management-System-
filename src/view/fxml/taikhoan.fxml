<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.TaiKhoanController"
      styleClass="content-area" spacing="16"
      stylesheets="@../css/style.css">

    <!-- ── Phase 3: Page Section Header ── -->
    <HBox styleClass="table-page-header" alignment="CENTER_LEFT" spacing="14"
          style="-fx-margin: -16 -16 0 -16;">
        <Label text="🔐" style="-fx-font-size: 22px;" />
        <VBox spacing="3">
            <Label text="Quản lý Tài khoản" styleClass="page-section-title" />
            <Label text="Phân quyền và quản trị tài khoản hệ thống" styleClass="page-section-sub" />
        </VBox>
    </HBox>

    <!-- ── Cảnh báo Admin-only ── -->
    <Label text="🔐  Chỉ quản trị viên (Admin) mới truy cập được khu vực này."
           style="-fx-background-color: #FEF9C3; -fx-text-fill: #92400E;
                  -fx-padding: 11 18; -fx-background-radius: 10;
                  -fx-font-size: 12px; -fx-font-weight: bold;
                  -fx-border-color: #FDE68A; -fx-border-width: 1; -fx-border-radius: 10;" wrapText="true" />

    <!-- ── Thanh tìm kiếm & toolbar ── -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" promptText="🔍  Tìm tên, username..."
                   prefWidth="300" onAction="#handleSearch"
                   styleClass="search-field" />
        <Button text="🔍  Tìm kiếm"  styleClass="btn-primary"   onAction="#handleSearch" />
        <Button text="🔄  Làm mới"   styleClass="btn-secondary" onAction="#handleRefresh" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblCount" text="Tổng: 0 tài khoản" style="-fx-text-fill: #6B7280;" />
    </HBox>

    <!-- ── Bảng tài khoản ── -->
    <TableView fx:id="tblTaiKhoan" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colID"       text="ID"        prefWidth="50"  />
            <TableColumn fx:id="colUsername" text="Username"  prefWidth="130" />
            <TableColumn fx:id="colHoTen"    text="Họ tên"    prefWidth="200" />
            <TableColumn fx:id="colRole"     text="Vai trò"   prefWidth="100" />
            <TableColumn fx:id="colEmail"    text="Email"     prefWidth="190" />
            <TableColumn fx:id="colPhone"    text="SĐT"       prefWidth="120" />
            <TableColumn fx:id="colStatus"   text="Trạng thái" prefWidth="110" />
            <TableColumn fx:id="colNgayTao"  text="Ngày tạo"  prefWidth="130" />
        </columns>
    </TableView>

    <!-- ── Action bar ── -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="✏️  Sửa thông tin"     styleClass="btn-primary"   onAction="#handleEdit"          />
        <Button text="🔑  Đặt lại mật khẩu" styleClass="btn-secondary" onAction="#handleResetPassword"  />
        <Button text="✅  Kích hoạt / 🚫 Khoá" styleClass="btn-secondary" onAction="#handleToggleStatus" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="Double-click để sửa nhanh" style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;" />
    </HBox>
</VBox>
